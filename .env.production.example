# Template for .env.production — copy to `.env.production` (gitignored) and fill in.
#   cp .env.production.example .env.production
# Loaded by the `production` Spring profile, and injected into the `api`
# Docker service via `env_file: .env.production`.

# ── REQUIRED — production fails to start if unset ─────────────────────
APP_AUTH_TOKEN_SECRET=          # openssl rand -base64 64
SPRING_DATASOURCE_PASSWORD=
RAZORPAY_WEBHOOK_SECRET=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=

# ── Razorpay API credentials ──────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Integrations (optional; YAML defaults to empty) ───────────────────
# Google Analytics server-side conversions (Measurement Protocol).
# Create one Measurement Protocol API secret PER property:
#   GA → Admin → Data Streams → <stream> → Measurement Protocol API secrets.
# Primary property (dashboard / B2B funnel); measurement-id defaults to
# G-7R463ZX69B in YAML:
GA_API_SECRET=
# B2C property (assessment app, G-BNS71Q704M). Optional — if blank, B2C
# conversions fall back to the primary property/secret above.
GA_B2C_API_SECRET=
OPENAI_API_KEY=
# APP_MANDRILL=
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
ODOO_URL=https://career-91.odoo.com
ODOO_DATABASE=career-91
ODOO_USERNAME=
ODOO_API_KEY=
GMAIL_SENDER=notifications@career-9.net
SMTP_USERNAME=notifications@career-9.net
SMTP_PASSWORD=

# ── MySQL container root password (if compose uses ${MYSQL_ROOT_PASSWORD}) ──
MYSQL_ROOT_PASSWORD=
