# .env — copy from .env.example and fill in real values. Never commit .env.
# Spring Boot reads these via OS environment variables (relaxed binding:
# APP_AUTH_TOKEN_SECRET ↔ app.auth.tokenSecret).

# ─────────────────────────────────────────────────────────────────────
# CRITICAL — application will NOT START if any of these are unset.
# Generate per environment, store in deployment secrets manager.
# ─────────────────────────────────────────────────────────────────────

# JWT signing secret (HS512). Generate with: openssl rand -hex 64
# MUST be unique per environment (dev/staging/sandbox/production).
APP_AUTH_TOKEN_SECRET=

# MySQL root password. Rotate via: ALTER USER root IDENTIFIED BY '<new>';
SPRING_DATASOURCE_PASSWORD=

# Razorpay webhook secret — copy from Razorpay Dashboard → Settings → Webhooks.
# In staging/sandbox/production, application startup fails if empty.
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Razorpay API credentials (used to create payment links)
# ─────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─────────────────────────────────────────────────────────────────────
# OpenAI API key — used by report generation features.
# Rotate the leaked sk-proj-v4_HscC... key immediately.
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Mandrill (transactional email)
# ─────────────────────────────────────────────────────────────────────
APP_MANDRILL=

# ─────────────────────────────────────────────────────────────────────
# DigitalOcean Spaces (file uploads)
# ─────────────────────────────────────────────────────────────────────
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# ─────────────────────────────────────────────────────────────────────
# Odoo integration
# ─────────────────────────────────────────────────────────────────────
ODOO_URL=
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# OAuth client secrets — externalized in Phase 13 (config-only, no code change).
# Required (fail-fast) in production / staging / sandbox.
# Optional in dev — defaults to literal "placeholder-dev-only" via application.yml
# so devs who don't use OAuth locally can still boot.
# Source: Google Cloud Console / Facebook Developers / GitHub Developer Settings.
# ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Gmail SMTP (optional — defaults to notifications@career-9.net)
# ─────────────────────────────────────────────────────────────────────
GMAIL_SENDER=notifications@career-9.net
SMTP_USERNAME=notifications@career-9.net
# Get from: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# MySQL container root password (only used when running docker-compose
# with the mysql_db_api / mysql_db_staging services uncommented)
# ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# Setup instructions:
#   1. cp .env.example .env
#   2. Fill in every CRITICAL value (or app will not start).
#   3. Generate APP_AUTH_TOKEN_SECRET fresh:  openssl rand -hex 64
#   4. Never commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────
