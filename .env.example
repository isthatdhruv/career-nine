# Copy to .env and fill in real values. Never commit .env (it's gitignored).
#
# This is the SINGLE source of env vars for every Spring profile.
#   - Local mvn:  loaded via spring.config.import (./.env or ../.env)
#   - Docker:     loaded via the api / api-staging services' env_file: .env
#
# Spring Boot reads these via OS environment variables (relaxed binding:
# APP_AUTH_TOKEN_SECRET ↔ app.auth.tokenSecret).

# ─────────────────────────────────────────────────────────────────────
# CRITICAL — production / sandbox will FAIL to start if these are unset.
# Dev has YAML fallbacks for most, so local boot works without them.
# ─────────────────────────────────────────────────────────────────────

# JWT signing secret (HS512). Generate with: openssl rand -base64 64
# MUST be unique per environment (dev / sandbox / production).
APP_AUTH_TOKEN_SECRET=

# MySQL root password — must match the password set on the mysql_db_api
# container. Docker-compose currently hardcodes 'Career-qCsfeuECc3MW' on
# the mysql_db_api / mysql_db_staging services, so this value must match
# for the api service to connect under the production profile.
SPRING_DATASOURCE_PASSWORD=

# Razorpay webhook secret — copy from Razorpay Dashboard → Settings → Webhooks.
# Required in sandbox/production (no YAML default).
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────
# OAuth client secrets — required (fail-fast) in production/sandbox.
# Dev has placeholder defaults in application-dev.yml so local boot works
# without these set.
# Source: Google Cloud Console / Facebook Developers / GitHub Developer Settings.
# ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_SECRET=
GITHUB_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────
# Razorpay API credentials (used to create payment links)
# ─────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─────────────────────────────────────────────────────────────────────
# OpenAI API key — used by report generation features.
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Mandrill (transactional email)
# ─────────────────────────────────────────────────────────────────────
APP_MANDRILL=

# ─────────────────────────────────────────────────────────────────────
# DigitalOcean Spaces (file uploads)
# DO_SPACES_ENDPOINT defaults to sgp1 in YAML; override only if you
# switched regions.
# ─────────────────────────────────────────────────────────────────────
DO_SPACES_ACCESS_KEY=
DO_SPACES_SECRET_KEY=
DO_SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com

# ─────────────────────────────────────────────────────────────────────
# Odoo integration (XML-RPC API)
# ─────────────────────────────────────────────────────────────────────
ODOO_URL=
ODOO_DATABASE=
ODOO_USERNAME=
ODOO_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Gmail SMTP (sender + app password from https://myaccount.google.com/apppasswords)
# GMAIL_SENDER + SMTP_USERNAME both default to notifications@career-9.net in YAML.
# ─────────────────────────────────────────────────────────────────────
GMAIL_SENDER=notifications@career-9.net
SMTP_USERNAME=notifications@career-9.net
SMTP_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# MySQL container root password (read by mysql_db_api / mysql_db_staging
# services in docker-compose.yml when overridden — currently hardcoded
# there to Career-qCsfeuECc3MW; keep this in sync if you switch compose
# to ${MYSQL_ROOT_PASSWORD} substitution).
# ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=

# ─────────────────────────────────────────────────────────────────────
# Setup instructions:
#   1. cp .env.example .env
#   2. Fill in every CRITICAL value (or production/sandbox boot will fail).
#   3. Generate APP_AUTH_TOKEN_SECRET fresh:  openssl rand -base64 64
#   4. Never commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────
