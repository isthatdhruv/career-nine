{
  "name": "career-nine-assessment",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync-cache": "bash scripts/cache-assessment.sh",
    "build": "bash scripts/cache-assessment.sh && tsc -b && vite build && node scripts/generate-manifest.cjs",
    "build:staging": "bash scripts/cache-assessment.sh https://staging.api.kccitm.in && vite build --mode staging && node scripts/generate-manifest.cjs",
    "build:production": "bash scripts/cache-assessment.sh https://api.career-9.com && vite build --mode production && node scripts/generate-manifest.cjs",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22",
    "axios": "^1.13.5",
    "bootstrap": "^5.3.8",
    "firebase": "^12.9.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.30.3",
    "webgazer": "^3.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.5.0",
    "vite-plugin-pwa": "^1.2.0"
  }
}
