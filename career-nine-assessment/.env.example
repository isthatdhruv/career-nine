# ─────────────────────────────────────────────────────────────────────────
# career-nine-assessment — Vite environment variables
#
# Vite reads files in this order (later overrides earlier):
#   .env  ←  .env.[mode]  ←  .env.local  ←  .env.[mode].local
# where [mode] is one of: development | staging | production.
#
# Copy this file to .env.development (etc.) and fill in the values.
# Variables MUST start with VITE_ to be exposed to the browser bundle.
# ─────────────────────────────────────────────────────────────────────────

# Backend API URL (e.g. https://api.career-9.com or http://localhost:8091).
# All XHR from src/api/http.ts is rooted at this baseURL.
VITE_API_URL=

# ─────────────────────────────────────────────────────────────────────────
# Phase 19 — cookie-based assessment-auth feature flag.
#
# When 'true', the SPA calls POST /auth/assessment-session after student
# identity is resolved (post-login on AllottedAssessmentPage, post-register
# on AssessmentRegisterPage / CampaignRegisterPage) and uses the resulting
# `cn_at_asmnt` HttpOnly cookie for:
#   /assessments/**, /assessment-answer/**, /student-demographics/**,
#   /heartbeat/**, /assessment-proctoring/**, /live-tracking/**, /student-info/**
#
# Default 'false' → legacy v2.0 X-Assessment-Session header path. Production
# builds default to off until per-institute rollout (driven by the backend
# flag `InstituteDetail.assessmentCookieAuthEnabled` per Plan 19-01) is
# complete. Staging builds can opt in by setting this to 'true'.
#
# On a 404 from POST /auth/assessment-session (per-institute flag OFF for
# the active student), the SPA transparently falls back to the v2.0 header
# path for that student — no user-visible error.
VITE_ASSESSMENT_COOKIE_AUTH=false
