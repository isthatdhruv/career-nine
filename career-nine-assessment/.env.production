VITE_API_URL=https://api.career-9.com

# Master proctoring kill-switch (see src/utils/proctoringFlag.ts).
# Set to false + rebuild + redeploy to disable ALL proctoring (camera, gaze
# tracking, face counting, click tracking, proctoring upload) — e.g. when the
# event load makes the proctoring pipeline too expensive.
VITE_PROCTORING_ENABLED=true
